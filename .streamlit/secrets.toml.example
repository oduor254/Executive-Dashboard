# Template only — do NOT fill this in and commit it. This file's values go
# into the Streamlit Community Cloud app's Settings -> Secrets text box
# (TOML format, same as this), not into a real .streamlit/secrets.toml here.
# (.streamlit/secrets.toml is gitignored if you ever do create one locally.)

DB_HOST = "your-db-host"
DB_PORT = "5432"
DB_NAME = "your-db-name"
DB_USER = "your-db-user"
DB_PASSWORD = "your-db-password"

REFRESH_INTERVAL_SECONDS = "120"

# Shared password for the dashboard login gate — choose your own value.
APP_PASSWORD = "choose-a-shared-password"
