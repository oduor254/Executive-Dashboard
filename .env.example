# Copy this file to .env and fill in your real values. .env is gitignored.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=denri
DB_USER=denri_app
DB_PASSWORD=

# Seconds between automatic chart/data refreshes on each page
REFRESH_INTERVAL_SECONDS=120

# Shared password required to view the dashboard. Choose your own value —
# this isn't auto-generated. Share it with the department out-of-band
# (Slack/WhatsApp), not by committing it anywhere.
APP_PASSWORD=

# Google service account key file for the "Sync to Sheet" button on the
# Offer Types tab (Product Sales page). Get a JSON key from Google Cloud
# Console (IAM & Admin -> Service Accounts), share the target sheet with
# its client_email as an Editor, then point this at the key file — keep it
# out of the repo (e.g. under a gitignored secrets/ folder).
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/gcp_service_account.json
DEALS_TRACKER_SHEET_ID=your-google-sheet-id
DEALS_TRACKER_GID=your-worksheet-gid
